# --- Project Delfino: Experimental Noise ---

# Ignore ALL CSVs in the root (results, copies, old versions)
# But keep the important parameters file
*.csv
!dummy_disease_params.csv
!labels.csv

# Ignore ALL Text files (trajectories/logs)
*.txt

# Ignore ALL PNGs (plots, copies)
*.png

# Ignore all temporary worker chunks
temp_*_*.csv

# Ignore all "decoded" or "readable" data artifacts
data/ukb_simulated_data/decoded_*.csv
data/ukb_simulated_data/human_readable_*.csv
data/ukb_simulated_data/preview_*.csv

# Ignore extra binary reconstructions
data/ukb_simulated_data/reconstructed_*.bin

# --- Machine Learning & Environment ---
__pycache__/
*.py[cod]
*$py.class
.venv/
env/
venv/
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Keep the Core Assets (The "!" means "Don't ignore") ---
!data/ukb_simulated_data/train.bin
!data/ukb_simulated_data/test.bin
!out-*/*.pt